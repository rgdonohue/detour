# Detour — copy to .env and fill in
ORS_API_KEY=your_openrouteservice_api_key
ORIGIN_NAME="New Mexico State Capitol"
ORIGIN_ADDRESS="411 South Capitol St, Santa Fe, NM 87501"
ORIGIN_LON=-105.9384
ORIGIN_LAT=35.6824
DEFAULT_RANGE_MILES=3
# 168 hours = 7 days. ORS road graph rarely changes; longer TTL means
# more cache hits for shared-URL replays and saved-tour traffic.
CACHE_TTL_HOURS=168
# Where to persist /api/area, /api/route cache files. Empty = repo-relative
# ./cache. In Railway, set to the mounted Volume path (e.g. /data/cache) so
# cache survives deploys.
CACHE_DIR=
# Set to true to enable ORS POI candidate discovery (experimental).
# In the current Railway deployment, changing this requires a restart or redeploy.
# Only active for: art, food. All other categories use static fallback.
USE_ORS_POIS=false
