  "stops": [
    {
      "order": 1,
      "name": "Loretto Chapel",
      "coordinates": [
        -105.93754,
        35.68562
      ],
      "category": "history",
      "description": "Famous for its mysterious 'miraculous staircase' \u2014 a circular, freestanding spiral with no visible central support, built around 1878. The Gothic Revival chapel was constructed for the Sisters of Loretto by Archbishop Lamy's builder. Now a museum and wedding venue, it marks the beginning of this walk along Old Santa Fe Trail."
    },
    {
      "order": 2,
      "name": "Barrio de Analco",
      "coordinates": [
        -105.9379485,
        35.6836817
      ],
      "category": "culture",
      "description": "One of the oldest continuously inhabited neighborhoods in the United States, settled in the early 1600s by Mexican and Tlaxcalan Indian servants who worked for the Spanish colonial government. The Barrio's adobe homes along De Vargas Street reflect over four centuries of New Mexican vernacular architecture and community life."
    },
    {
      "order": 3,
      "name": "San Miguel Chapel",
      "coordinates": [
        -105.93756879,
        35.68345568
      ],
      "category": "culture",
      "description": "Often cited as the oldest church still in use in the United States, with origins around 1610. The current structure was rebuilt after the Pueblo Revolt of 1680 and reconstructed again in 1710. Thick adobe walls and hand-hewn wood beam ceilings survive from that era. The chapel houses a 780-pound bell cast in 1356."
    },
    {
      "order": 4,
      "name": "New Mexico State Capitol",
      "coordinates": [
        -105.939027,
        35.682226
      ],
      "category": "civic",
      "description": "The only circular state capitol building in the United States, known as the Roundhouse. Completed in 1966 and designed to echo the Zia Pueblo sun symbol, it sits at the center of state government surrounded by sculpture gardens and native plantings. The rotunda interior features New Mexican art from across the state's history."
    },
    {
      "order": 5,
      "name": "Water Bearers",
      "coordinates": [
        -105.9383399,
        35.6818158
      ],
      "category": "history",
      "description": "A bronze monument on the Capitol grounds honoring the acequia tradition of community water management that sustained Santa Fe since Spanish colonial settlement. The figure carries water in traditional vessels \u2014 a reminder that this city was built in a high-desert environment where water was managed communally and carefully."
    },
    {
      "order": 6,
      "name": "Gerald Peters Gallery",
      "coordinates": [
        -105.9340007,
        35.6817418
      ],
      "category": "art",
      "description": "One of the foremost galleries on Canyon Road, representing American and European art from the 19th century through the contemporary era. The gallery occupies a sprawling adobe compound with interior courtyards \u2014 an exemplar of the Canyon Road model where art and architecture merge into a single experience."
    },
    {
      "order": 7,
      "name": "El Zaguan",
      "coordinates": [
        -105.9300183,
        35.6822575
      ],
      "category": "history",
      "description": "A 19th-century hacienda on Canyon Road now owned by the Historic Santa Fe Foundation. The property is notable for its Victorian-era garden \u2014 one of the oldest in Santa Fe \u2014 with peony beds and fruit trees planted in the late 1800s. The garden is open to the public and offers a quiet respite from the gallery corridor."
    },
    {
      "order": 8,
      "name": "Cathedral Basilica of Saint Francis",
      "coordinates": [
        -105.93614391,
        35.68648866
      ],
      "category": "culture",
      "description": "The architectural centerpiece of Santa Fe's skyline, built by Archbishop Jean-Baptiste Lamy between 1869 and 1886 in Romanesque Revival style. Lamy imported French stonemasons to construct it, and the cathedral replaced an earlier adobe church on the site. The Lady Chapel inside preserves a 1625 wooden statue of the Virgin Mary that survived the Pueblo Revolt."
    },
    {
      "order": 9,
      "name": "Museum of Contemporary Native Arts",
      "coordinates": [
        -105.9370452,
        35.68705711
      ],
      "category": "history",
      "description": "Operated by the Institute of American Indian Arts, this museum on the south side of the Plaza presents contemporary work by Native artists from across the Americas. The building \u2014 a former Federal Building and Post Office \u2014 places Indigenous contemporary art at the literal center of Santa Fe's civic and cultural life."
    },
    {
      "order": 10,
      "name": "Santa Fe Plaza",
      "coordinates": [
        -105.93853097,
        35.68742063
      ],
      "category": "culture",
      "description": "The historic heart of Santa Fe since its founding as a Spanish colonial capital around 1610. The Plaza has served as a marketplace, military parade ground, and civic gathering space for over 400 years. The Palace of the Governors lines its north edge; portals along the perimeter shelter Native American jewelry and pottery vendors year-round."
    },
    {
      "order": 11,
      "name": "Palace of the Governors",
      "coordinates": [
        -105.93815262,
        35.68791375
      ],
      "category": "history",
      "description": "The oldest continuously occupied public building in the United States, constructed around 1610 as the seat of Spanish colonial government in New Mexico. Occupied successively by Spanish governors, Pueblo leaders during the Revolt, Mexican governors, and US territorial governors, it is now a museum of New Mexican history. Its long portal is one of the most recognized images of Santa Fe."
    },
    {
      "order": 12,
      "name": "New Mexico Museum of Art",
      "coordinates": [
        -105.9391366,
        35.6882471
      ],
      "category": "art",
      "description": "Founded in 1917, this Pueblo Revival landmark anchors the northwest corner of the Plaza. Designed by I.H. and William Rapp, the building established the architectural vocabulary that would define Santa Fe's civic aesthetic for a century. The collection centers on New Mexican and Southwestern art, with a particular depth in early 20th-century regional painters."
    },
    {
      "order": 13,
      "name": "Georgia O'Keeffe Museum",
      "coordinates": [
        -105.94117807,
        35.68917733
      ],
      "category": "art",
      "description": "The world's largest collection of Georgia O'Keeffe's work, celebrating the artist who made New Mexico's high desert landscape her lifelong subject. O'Keeffe moved permanently to New Mexico in 1949 and lived there until her death in 1986. The museum \u2014 founded in 1997 in a historic adobe complex \u2014 holds over 3,000 of her works."
    },
    {
      "order": 14,
      "name": "The Lensic",
      "coordinates": [
        -105.94106468,
        35.68789992
      ],
      "category": "culture",
      "description": "A 1931 Moorish-Spanish Renaissance movie palace restored in 2001 as Santa Fe's premier performing arts venue. The Lensic Performing Arts Center now hosts opera, jazz, film, and theater \u2014 a cultural anchor on West San Francisco Street, one block from the Plaza. The restored interior retains its original ornate detailing and 820-seat balcony."
    }
  ]
}
